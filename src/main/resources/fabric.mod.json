{
	"schemaVersion": 1,
	"id": "nohotbaritemname",
	"version": "${version}",
	"name": "NoHotbarItemName",
	"description": "Removes the text of the name of the item your holding that shows above the hotbar.",
	"authors": [
		"VespoMC"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/nohotbaritemname/icon.png",
	"environment": "*",
	"entrypoints": {
		"client": [
			"com.nohotbaritemname.client.NoHotbarItemNameClient"
		]
	},
	"mixins": [
		"nohotbaritemname.mixins.json",
		{
			"config": "nohotbaritemname.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}